#!../bin/quickstream --interpreter

# Testing the simple interpreter

# We add some irregular lines to test the parsing.

v 4
threads 5
block tests/sequenceGen gen
block tests/copy c0
block tests/copy c1
block tests/passThrough p2
  block    tests/passThrough   p3  # comment at end of line
 block tests/sequenceCheck out
connect gen 0 c0 0
connect c0 0 c1 0
connect c1 0 p2 0
connect p2 0 p3 0
connect p3 0 out 0
run

# Done.
