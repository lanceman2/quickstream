<?xml version="1.0"?>
<!-- GTK+3 widgets for quickstreamBuilder for block popup menu -->
<interface>
  <object id="popupMenu" class="GtkMenu">
    <property name="visible">True</property>
    <property name="can_focus">True</property>
    <child>
      <object id="properties" class="GtkMenuItem">
        <property name="label">Properties ...</property>
        <property name="visible">True</property>
      </object>
    </child>
    <child>
      <object id="remove" class="GtkMenuItem">
        <property name="label">Remove</property>
        <property name="visible">True</property>
      </object>
    </child>
    <child>
      <object id="rotateCW" class="GtkMenuItem">
        <property name="label">Rotate CW</property>
        <property name="visible">True</property>
      </object>
    </child>
    <child>
      <object id="rotateCCW" class="GtkMenuItem">
        <property name="label">Rotate CCW</property>
        <property name="visible">True</property>
      </object>
    </child>
    <child>
      <object id="flip" class="GtkMenuItem">
        <property name="label">Flip</property>
        <property name="visible">True</property>
      </object>
    </child>
    <child>
      <object id="flop" class="GtkMenuItem">
        <property name="label">Flop</property>
        <property name="visible">True</property>
      </object>
    </child>
  </object>
</interface>
