<!-- GTK+3 widgets for quickstreamBuilder for block popup menu -->
<interface>
    <object id="popupMenu" class="GtkMenu">
        <property name="visible">True</property>
        <property name="can_focus">True</property>
        <child>
            <object id="remove" class="GtkMenuItem">
                <property name="label">Remove</property>
                <property name="visible">True</property>
            </object>
        </child>
        <child>
            <object id="rotateCCW" class="GtkMenuItem">
                <property name="label">Rotate CCW</property>
                <property name="visible">True</property>
            </object>
        </child>
        <child>
            <object id="rotateCW" class="GtkMenuItem">
                <property name="label">Rotate CW</property>
                <property name="visible">True</property>
            </object>
         </child>
    </object>
</interface>
