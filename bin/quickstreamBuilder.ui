<!-- GTK+3 widgets for quickstreamBuilder -->
<interface>
    <object id="window" class="GtkWindow">
        <property name="visible">True</property>
        <property name="title">quickstream builder</property>
        <property name="border-width">0</property>
        <child>
            <object id="topBox" class="GtkBox">
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="margin_left">8</property>
                <property name="margin_right">8</property>
                <property name="margin_top">8</property>
                <property name="margin_bottom">8</property>
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>

                <child>
                <!--**********************************************************-->
                <!--                   Main MenuBar                           -->
                <!--**********************************************************-->
                    <object id="mainMenuBar" class="GtkMenuBar">
                        <property name="visible">True</property>

                        <!-- File Menu -->
                        <child>
                            <object id="menuItemFile" class="GtkMenuItem">
                                <property name="label">File</property>
                                <property name="visible">True</property>
                                <child type="submenu">
                                    <object class="GtkMenu">
                                        <property name="visible">True</property>
                                        <property name="can_focus">True</property>
                                        <child>
                                            <object class="GtkMenuItem" id="copyMenu">
                                                <property name="label">Open</property>
                                                <property name="visible">True</property>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="GtkMenuItem" id="saveMenu">
                                                <property name="label">Save</property>
                                                <property name="visible">True</property>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="GtkMenuItem" id="quitMenu">
                                                <property name="label">Quit</property>
                                                <property name="visible">True</property>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>

                        <!-- Edit Menu -->
                        <child>
                            <object id="menuItemEdit" class="GtkMenuItem">
                                <property name="visible">True</property>
                                <property name="label">Edit</property>
                            </object>
                        </child>

                        <!--  View Menu -->
                        <child>
                            <object id="menuItemView" class="GtkMenuItem">
                                <property name="visible">True</property>
                                <property name="label">View</property>
                            </object>
                        </child>

                        <!--  Help Menu -->
                        <child>
                            <object id="menuItemHelp" class="GtkMenuItem">
                                <property name="visible">True</property>
                                <property name="label">Help</property>
                            </object>
                        </child>



                    </object>
                    <packing>
                        <property name="expand">False</property>
                    </packing>
                </child>


                <child>
                <!--**********************************************************-->
                <!--                   Main Work Area                         -->
                <!--**********************************************************-->
                    <object id="workArea" class="GtkLayout">
                        <property name="visible">True</property>
                    </object>
                    <packing>
                        <property name="expand">True</property>
                    </packing>
                </child>


                <child>
                <!--**********************************************************-->
                <!--                   Status Bar                             -->
                <!--**********************************************************-->
                    <object id="grid" class="GtkGrid">
                        <property name="visible">True</property>
                        <child>
                            <object id="button1" class="GtkButton">
                                <property name="visible">True</property>
                                <property name="label">Button 1</property>
                            </object>
                            <packing>
                                <property name="left-attach">0</property>
                                <property name="top-attach">0</property>
                            </packing>
                        </child>
                        <child>
                            <object id="button2" class="GtkButton">
                                <property name="visible">True</property>
                                <property name="label">Button 2</property>
                            </object>
                            <packing>
                                <property name="left-attach">1</property>
                                <property name="top-attach">0</property>
                            </packing>
                        </child>
                        <child>
                            <object id="quitButton" class="GtkButton">
                                <property name="visible">True</property>
                                <property name="label">Quit</property>
                            </object>
                            <packing>
                                <property name="left-attach">0</property>
                                <property name="top-attach">1</property>
                                <property name="width">2</property>
                            </packing>
                        </child>
                    </object>
                    <packing>
                        <property name="expand">False</property>
                    </packing>
                </child>



            </object>
        </child>

    </object>
</interface>
