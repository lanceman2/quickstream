<!-- GTK+3 widgets for quickstreamBuilder -->
<interface>
    <object id="window" class="GtkWindow">
        <property name="visible">True</property>
        <property name="title">quickstream builder</property>
        <property name="border-width">0</property>
        <child>
            <object id="topBox" class="GtkBox">
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="margin_left">0</property>
                <property name="margin_right">0</property>
                <property name="margin_top">0</property>
                <property name="margin_bottom">0</property>
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>
                <property name="orientation">vertical</property>
                <property name="spacing">0</property>

                <child>
                <!--**********************************************************-->
                <!--                   Main MenuBar                           -->
                <!--**********************************************************-->
                    <object id="mainMenuBar" class="GtkMenuBar">
                        <property name="visible">True</property>

                        <!-- File Menu -->
                        <child>
                            <object id="menuItemFile" class="GtkMenuItem">
                                <property name="label">File</property>
                                <property name="visible">True</property>
                                <child type="submenu">
                                    <object class="GtkMenu">
                                        <property name="visible">True</property>
                                        <property name="can_focus">True</property>
                                        <child>
                                            <object class="GtkMenuItem" id="copyMenu">
                                                <property name="label">Open</property>
                                                <property name="visible">True</property>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="GtkMenuItem" id="saveMenu">
                                                <property name="label">Save</property>
                                                <property name="visible">True</property>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="GtkMenuItem" id="quitMenu">
                                                <property name="label">Quit</property>
                                                <property name="visible">True</property>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>

                        <!-- Edit Menu -->
                        <child>
                            <object id="menuItemEdit" class="GtkMenuItem">
                                <property name="visible">True</property>
                                <property name="label">Edit</property>
                            </object>
                        </child>

                        <!--  View Menu -->
                        <child>
                            <object id="menuItemView" class="GtkMenuItem">
                                <property name="visible">True</property>
                                <property name="label">View</property>
                            </object>
                        </child>

                        <!--  Help Menu -->
                        <child>
                            <object id="menuItemHelp" class="GtkMenuItem">
                                <property name="visible">True</property>
                                <property name="label">Help</property>
                            </object>
                        </child>



                    </object>
                    <packing>
                        <property name="expand">False</property>
                    </packing>
                </child>



                <child>
                <!--**********************************************************-->
                <!--                   Button Bar                             -->
                <!--**********************************************************-->
                    <object id="buttonBox" class="GtkBox">
                        <property name="visible">True</property>
                        <property name="can_focus">False</property>
                        <property name="margin_left">8</property>
                        <property name="margin_right">8</property>
                        <property name="margin_top">8</property>
                        <property name="margin_bottom">8</property>
                        <property name="hexpand">True</property>
                        <property name="vexpand">False</property>
                        <property name="orientation">horizontal</property>
                        <property name="spacing">2</property>

                        <!-- Quit Button -->
                        <child>
                            <object id="quitButton" class="GtkButton">
                                <property name="label">Quit</property>
                                <property name="can_focus">True</property>
                                <property name="visible">True</property>
                            </object>
                        </child>
                    </object>
                    <packing>
                        <property name="expand">False</property>
                    </packing>
                </child>



                <child>
                <!--**********************************************************-->
                <!--                   Vertical Pane                          -->
                <!--**********************************************************-->
                    <object id="vpanel" class="GtkPaned">
                        <property name="visible">True</property>
                        <property name="orientation">vertical</property>
                        <property name="can_focus">True</property>

                        <child>
                        <!--**********************************************************-->
                        <!--                   Main Work Area                         -->
                        <!--**********************************************************-->
                            <object id="workArea" class="GtkLayout">
                                <property name="visible">True</property>
                                <property name="can_focus">True</property>
                                <property name="focus_on_click">True</property>
                                <property name="events">GDK_STRUCTURE_MASK |
                                    GDK_SCROLL_MASK |
                                    GDK_POINTER_MOTION_MASK |
                                    GDK_BUTTON_RELEASE_MASK |
                                    GDK_BUTTON_PRESS_MASK|
                                    GDK_STRUCTURE_MASK 
                                </property>
                            </object>
                            <packing>
                                <property name="resize">True</property>
                                <property name="shrink">True</property>
                            </packing>
                        </child>



                        <child>
                        <!--**********************************************************-->
                        <!--                   Status Bar                             -->
                        <!--**********************************************************-->

                            <object id="statusScroll" class="GtkScrolledWindow">
                                <property name="visible">True</property>
                                <child>
                                    <object id="status" class="GtkTextView">
                                        <property name="visible">True</property>
                                    </object>
                                </child>
                            </object>
                            <packing>
                                <property name="resize">False</property>
                                <property name="shrink">True</property>
                            </packing>
                        </child>



                    </object>
                    <packing>
                        <property name="expand">True</property>
                    </packing>
                </child>


            </object>
        </child>

    </object>

</interface>



<object class="GtkIconFactory" id="iconFactory">
    <sources>
        <source stock-id="inputIcon" filename="input.png"/>
    </sources>
    <sources>
        <source stock-id="inputIcon" filename="output.png"/>
    </sources>
</object>

